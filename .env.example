# MONGO_URI: Connection string for MongoDB.
MONGO_URI="mongodb+srv://<db_user>:<db_password>@<cluster-host>/<db-name>?retryWrites=true&w=majority"
# ADMIN_PASSWORD: Secret used to access /admin and write APIs.
ADMIN_PASSWORD="change_me_to_a_strong_secret"
# DNS_SERVERS: Optional comma-separated DNS servers used by Node for SRV lookups.
DNS_SERVERS="8.8.8.8,1.1.1.1"
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional frontend API base URL for production builds.
# Set this when frontend and backend are deployed on different domains.
# Example:
# VITE_API_BASE_URL="https://your-backend.example.com/api"
